%main#frontpage.main.selectable{ data: { 'controller': "frontpage header", 'action': "click->header#hideNavDropdown" } }
  / Hero Section
  #hero.hero.section.dark-background
    .hero-bg-image{ 'data-aos': "zoom-out", 'data-aos-once': "true" }

    / News Banner – update the text below to advertise new features or site news.
    / Remove or comment out this block when there is nothing to announce.
    .banner-explorer{ role: "note", 'aria-label': _("News") }
      .banner-explorer-inner
        .banner-explorer-content
          %h6= _("Bicycle Touring!")
          .divider
          %p
            = _("Tour planning with Mapforge:")
            =link_to _('See how it works'), '/doc/bike_touring'

    .container
      .row
        .col-lg-6.welcome-text
          %h1.d-none.d-sm-inline.mapforge-font{ 'data-aos': "fade-up" }= _("Create your own map")
          %h1.d-sm-none.mapforge-font{ 'data-aos': "fade-up" }= _("Create your map")

          %div{ 'data-aos': "fade-up" }
            %blockquote{ 'data-aos': "fade-up" }
              %p
                %span.d-none.d-sm-inline
                  = _("Your free, open-source map editor built on OpenStreetMap. Create individual maps for your places, tracks and events - customize, collaborate and share in real-time.")
                %span.d-sm-none
                  = _("Your open-source map editor built on OpenStreetMap. Create individual maps for your places, tracks and events.")
                - tutorial_link = link_to(_('tutorial map'), tutorial_path, class: 'btn btn-orange call-to-action', data: { turbo_method: :post })
                - if @user
                  - maps_link = link_to(_('your maps'), my_path, class: 'btn btn-orange call-to-action')
                  - create_link = link_to(_('create'), create_map_path, class: 'btn btn-orange call-to-action', data: { turbo_method: :post })
                  %p= raw(_("Browse %{maps_link}, learn more on the %{tutorial_link} or %{create_link} a new map.") % { maps_link: maps_link, tutorial_link: tutorial_link, create_link: create_link })
                - else
                  - gallery_link = link_to(_('gallery'), maps_path, class: 'btn btn-orange call-to-action')
                  - login_link = link_to(_('log in'), login_path, class: 'btn btn-orange call-to-action')
                  %p= raw(_("Browse the %{gallery_link}, learn how to use Mapforge on the %{tutorial_link} or %{login_link} to create your own maps.") % { gallery_link: gallery_link, tutorial_link: tutorial_link, login_link: login_link })
                %p
                  %span.d-none.d-sm-inline
                    = _("Mapforge is ad-free and respects your privacy.")
                    = _("Also available for self-hosting, giving you full control over your data.")
                  /%span.d-sm-none
                  /  - app_link = link_to(_('app'), doc_path(id: 'app'), class: 'btn btn-orange call-to-action')
                  /  = raw(_("Also available as %{app_link}.") % { app_link: app_link })
            %p.fs-4.mapforge-font
              %i= _("Happy mapping!")

    .container.feature-tour-col{ 'data-aos': "fade-up", 'data-aos-offset': "0" }
      .col-lg-6.d-flex.justify-content-center
        %a.feature-tour-link{ href: "#features", data: { action: "click->frontpage#scrollToFeatures" } }
          = _("Feature Tour")
          %i.bi.bi-chevron-double-down

  %section#features.why-us.section
    .row.g-0
      .col-lg-5.img-bg.d-none.d-sm-block
        %img{ src: "/images/frontpage/feature0.png",
              id: 'swiper-image', alt: _("Background"), loading: 'lazy' }
      .col-lg-5.img-bg.d-sm-none
        %img{ src: "/images/frontpage/feature0_small.png",
              id: 'swiper-image-mobile', alt: _("Background"), loading: 'lazy' }
      .col-lg-7.background-dark.slides.position-relative
        .swiper.init-swiper
          .swiper-wrapper
            .swiper-slide
              .item
                %h2.mb-3.mapforge-font= _("Map tools")
                %h4.mb-3= _("Customize your map")
                %ul
                  %li
                    %span.d-none.d-sm-inline><
                      = _("Choose your base map: Streets, Satellite, Topographic, Biking, 3D houses etc.")
                    %span.d-sm-none><
                      = _("Choose your base map: Streets, Satellite, Topographic, Biking")
                  %li
                    = _("Add your own data:")
                    %span.d-none.d-sm-inline
                      = _("Import your data from GeoJSON, GPX and KML")
                    %span.d-sm-none
                      = _("Import from GeoJSON, GPX and KML")
                  %li
                    = _("Draw shapes and style them:")
                    %span.d-none.d-sm-inline><
                      = _("Add pictures, customize colors, symbols, labels, (3D) polygons and more")
                    %span.d-sm-none
                      = _("Add pictures, customize colors, symbols, labels")
                  %li
                    - overpass_link = link_to 'Overpass', doc_path(id: 'overpass_layers')
                    = raw(_("Dynamic layers: Use %{overpass_link} to add custom layers from OpenStreetMap data") % { overpass_link: overpass_link })
                  %li
                    %span.d-none.d-sm-inline
                      = _("3D Terrain: View your map with realistic elevation")
                    %span.d-sm-none
                      = _("3D Terrain: View your map with elevation")
            .swiper-slide
              .item
                %h2.mb-3.mapforge-font= _("Collaboration")
                %h4.mb-3= _("Work with others and stream map changes to all connected clients")
                %ul
                  %li= _("Live updates: Map changes are synchronized via websockets")
                  %li= _("Login: Have your maps assigned to your account")
                  %li= _("Access control: Keep maps private or share with view-only or edit permissions")
            .swiper-slide
              .item
                %h2.mb-3.mapforge-font= _("Cross platform")
                %h4.mb-3= _("Use Mapforge with different clients + apps")
                %ul
                  %li= _("Responsive Design: Works well both on desktop and mobile")
                  %li
                    - app_link = link_to _('app on your phone'), doc_path(id: 'app')
                    = raw(_("Run from your home screen as %{app_link}") % { app_link: app_link })
                  %li
                    - ulogger_link = link_to "µlogger", "https://github.com/mapforge-org/mapforge/blob/main/engines/ulogger/README.md"
                    = raw(_("Map your track: Use %{ulogger_link} to visualize and share your tracks live") % { ulogger_link: ulogger_link })
            .swiper-slide
              .item
                %h2.mb-3.mapforge-font= _("Open Source")
                %h4.mb-3= "\"Standing on the shoulders of giants\""
                %ul
                  %li
                    - rails_link = link_to "Ruby on Rails", "https://rubyonrails.org/"
                    - maplibre_link = link_to "MapLibre GL JS", "https://github.com/maplibre/maplibre-gl-js"
                    - osm_link = link_to "OpenStreetMap", "https://www.openstreetmap.org"
                    - draw_link = link_to "mapbox-gl-draw", "https://github.com/mapbox/mapbox-gl-draw"
                    - turf_link = link_to "Turf.js", "https://turfjs.org/"
                    - ors_link = link_to "Openrouteservice", "https://openrouteservice.org/"
                    = raw(_("Used open source projects: %{rails_link} for the backend, %{maplibre_link} and %{osm_link} for the frontend, %{draw_link}, %{turf_link}, %{ors_link} as helping libraries.") % { rails_link: rails_link, maplibre_link: maplibre_link, osm_link: osm_link, draw_link: draw_link, turf_link: turf_link, ors_link: ors_link })
                  %li
                    = _("Storing only minimal data about you, no sharing of data with ad- or analytics companies.")
                  %li
                    - mapforge_link = link_to("mapforge.org", "https://mapforge.org")
                    - deploy_link = link_to _('deploy'), "https://github.com/mapforge-org/mapforge/blob/main/README.md"
                    = raw(_("Self-Hosted Solution: You can use Mapforge either on %{mapforge_link}, or %{deploy_link} it in your own infrastructure") % { mapforge_link: mapforge_link, deploy_link: deploy_link })
          .swiper-pagination
        .swiper-button-prev
        .swiper-button-next
