- content_for :title, "Mapforge: Recently watched and My maps"

#maps

  - if @recent_maps.present?
    %h1.mapforge-font Recently viewed Maps
    .maps-list.recently-viewed-maps.mb-4
      - @recent_maps.each do |recent_map, rw|
        = render recent_map, rw: rw


  %h1.mapforge-font
    Your Maps

  = render "list_filter"
  = render "list" , maps: @my_maps, rw: true, delete: true, clone: false, last_change: false


  - if @my_maps.empty?
    .container.pt-4.pb-2.mt-4.mb-4.empty-map-list.background-bright
      %p.text-center
        In this gallery, your personal maps will be shown.
        %br
        You can try out the
        = link_to 'tutorial map', tutorial_path, class: 'btn btn-orange call-to-action', data: { turbo_method: :post }
        to learn how Mapforge works, or you can
        = link_to 'create', create_map_path, class: 'btn btn-orange call-to-action', data: { turbo_method: :post }
        your first map right away.
