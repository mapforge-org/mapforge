#share-modal.modal-center.fade
  .map-modal{'data-controller': "map--modal map--share", 'data-action': "keydown.esc@window->map--modal#close"}
    %button.modal-close-button{ data: { action: "click->map--modal#close" } } &times;
    .map-modal-header
      %h3.mapforge-font Share Map

    .map-modal-content.inline-scroll

      .feature-section-card.pt-3
        - if @map_mode == 'rw'
          - if @map.owners.any?
            %p
              %span.me-2
                - @map.owners.each do |owner|
                  - if owner.image
                    = image_tag avatar_url(owner.image, 40), class: 'map-avatar', title: owner.email, crossorigin: "anonymous", data: { "toggle": 'tooltip', 'bs-custom-class': 'maplibregl-ctrl-tooltip' }

              Access this map under '#{link_to "Your maps", my_path}'.
          - else
            %p
              This map was created anonymously and can only get changed with the
              = link_to 'edit link', @map.private_map_path
              = "."

          .row.mb-3
            .col-12
              .d-flex.gap-2
                %button#share-edit-link.form-button.btn.btn-blue.flex-grow-1{ type: "button" }
                  =link_to(map_path(@map.private_id), data: { turbo: false, action: "click->map--share#nativeShareEditLink" }) do
                    %i.bi.bi-link-45deg.me-1
                    Share edit link
                %button.btn.btn-outline-secondary{ type: "button", data: { action: "click->map--share#copyEditLink" }, title: "Copy link" }
                  %i.bi.bi-copy
              %small.text-muted.mt-2.flex-center
                Anyone with this link can modify the map, add layers, and make changes.

          .row.mb-3
            .col-12
              .d-flex.gap-2
                %button#share-view-link.form-button.btn.btn-blue.flex-grow-1{ type: "button" }
                  =link_to(map_path(id: @map.public_id), data: { turbo: false, action: "click->map--share#nativeShareViewLink" }) do
                    %i.bi.bi-link-45deg.me-1
                    Share view link
                %button.btn.btn-outline-secondary{ type: "button", data: { action: "click->map--share#copyViewLink" }, title: "Copy link" }
                  %i.bi.bi-copy
              %small.text-muted.mt-2.flex-center
                Users can explore the map but cannot modify it.

          .row.mb-2
            .col-md-12
              .form-check.form-switch.flex-center
                %input.form-check-input.me-2#map-gallery-toggle{ type: "checkbox", data: { action: "change->map--share#updateGalleryVisibility" }}
                %label.form-check-label{ for: "map-gallery-toggle" }
                  Show map in Mapforge gallery

        - else
          %label.form-label.mb-2
            %b View link
          .d-flex.gap-2
            %button#share-view-link.form-button.btn.btn-success.flex-grow-1{ type: "button" }
              =link_to(map_path(id: @map.public_id), data: {turbo: false, action: "click->map--share#nativeShareViewLink" }) do
                %i.bi.bi-link-45deg.me-1
                Share
            %button.btn.btn-outline-secondary{ type: "button", data: { action: "click->map--share#copyViewLink" }, title: "Copy link" }
              %i.bi.bi-copy
          %small.text-muted.mt-2.mb-3.d-block
            Recipients can explore the map but cannot modify it.

      .feature-section-card
        .btn-group-sm.mt-3{ role: "group" }
          %b.me-2 Download map as:
          %button.btn.btn-secondary.btn-download{ type: "button" }
            =link_to map_geojson_path(@map.public_id), target: '_blank' do
              %i.bi.bi-download
              GeoJSON
          %button.btn.btn-secondary.btn-download{ type: "button" }
            =link_to map_gpx_path(@map.public_id) do
              %i.bi.bi-download
              GPX
          %button.btn.btn-secondary.btn-download{ type: "button" }
            =link_to map_json_path(@map.public_id),target: '_blank' do
              %i.bi.bi-download
              Map export

      .feature-section-card.pt-2.d-none.d-sm-block
        %b.me-2.mt-2 Embed map:
        .me-2
          %textarea#embed-code.form-control{ rows: "3", readonly: "readonly" }
            = raw("<iframe width='600' height='450' style='border:0' loading='lazy' src='#{map_url(@map.public_id, { nomenu: true })}'></iframe>")
          %small.link.text-muted.flex-center.mt-1.text-nowrap{ data: { action: "click->map--share#copyEmbedCode" } }
            %i.bi.bi-copy.me-1
            Click to copy html to embed in your website