#feature-edit-raw

  %textarea.embed-code.form-control{name: "properties", rows: "6", cols: "50", "data-feature-target": "properties" }
  %span.error

  .d-flex.justify-content-between.align-items-center.mt-2
    %button.btn.btn-blue.feature-update{ 'data-action': "click->feature--edit#update_feature_raw"} Update
    = link_to doc_path(id: 'geojson_style_spec'), { target: '_blank', rel: 'noopener noreferrer', class: 'link text-nowrap' } do
      %i.bi.bi-box-arrow-up-right.me-1
      Style Help
