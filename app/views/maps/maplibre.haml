- unless params['static'] == 'true'
  -# map header and title
  %nav#map-head.dark-shadow
    - unless params['nomenu'] == 'true'
      #map-nav-toggle.navbar-toggler-icon.ms-2.me-2{ title: "Toggle Navigation", data: { 'controller': "header", 'action': "click->header#toggleNav", 'toggle': "tooltip", 'bs-placement': "bottom" } }
    %h1#map-title{ onclick: "document.querySelector('.maplibregl-ctrl-map').click()", title: "Map settings", data: { 'toggle': "tooltip", 'bs-placement': "bottom" } }= @map.name

- if params['nomenu'] == 'true'
  = link_to root_url, { '_target': 'blank' } do
    %img.mapforge-embed-logo{ src: "/icons/mapforge-logo-header_white.png", alt: "Logo" }

#maplibre-map.map{ data: { 'controller': "map header", 'action': "click->header#hideNav touchstart->header#hideNav keydown.ctrl+v@window->map#paste" } }

- unless @map_mode == 'static'
  = render 'layer_loading'
  = render 'status'
  = render 'maps/modals/settings'
  = render 'maps/modals/layers'
  = render 'maps/modals/share'
  = render 'maps/modals/feature'
  = render 'maps/modals/confirmation'
  = render 'maps/modals/description'
  = render 'maps/modals/context_menu'

#dropdown-space

#remote-cursor-template.remote-cursor.hidden
  %i.bi.bi-cursor-fill.remote-cursor-pointer